{
  "name": "map",
  "version": "0.1.3",
  "description": "Local-first couple memory map desktop app",
  "author": "Map of Us",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:keepalive": "bash scripts/dev-keepalive.sh",
    "dev:daemon": "bash scripts/start-dev-daemon.sh",
    "build": "next build",
    "desktop:prepare": "npm run build && node scripts/prepare-standalone.mjs",
    "preview": "next start",
    "start": "next start",
    "lint": "eslint",
    "desktop": "electron electron/main.js",
    "dist:dir": "npm run desktop:prepare && electron-builder --dir",
    "dist:mac": "npm run desktop:prepare && electron-builder --mac dmg",
    "dist:win": "npm run desktop:prepare && electron-builder --win nsis --x64"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.mapofus.desktop",
    "productName": "Map of Us",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "npmRebuild": false,
    "files": [
      "!node_modules/**/*",
      "electron/**/*",
      ".next/standalone/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "d3-geo": "^3.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "electron": "^42.5.2",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^5"
  }
}
